# Public browser variables
VITE_INSFORGE_URL=https://your-app.insforge.app
VITE_INSFORGE_ANON_KEY=replace_with_insforge_anon_key

# Server-only secrets. Never expose these in client code.
INSFORGE_API_KEY=replace_with_server_side_insforge_key
PORTALY_CHECKOUT_API_KEY=replace_with_portaly_checkout_server_key
PORTALY_CALLBACK_SECRET=replace_with_portaly_callback_secret
PORTALY_API_HOST=https://portaly.cc
PORTALY_CALLBACK_URL=https://your-domain.com/functions/portaly-webhook
PORTALY_API_TOKEN=mcp_ptly_xxx

# Optional preview login for local demos and forked templates.
# Keep the password and session token in Vercel/hosting env vars only.
MEMBERHUB_PREVIEW_EMAIL=owner@example.com
MEMBERHUB_PREVIEW_PASSWORD=replace_with_private_preview_password
MEMBERHUB_PREVIEW_SESSION_TOKEN=replace_with_random_64_char_token
MEMBERHUB_PREVIEW_ROLE=admin

# App URLs
APP_BASE_URL=http://localhost:5176
ALLOWED_ORIGINS=http://localhost:5176,http://127.0.0.1:5176

# Optional analytics and messaging
GA_MEASUREMENT_ID=
LINE_CHANNEL_ACCESS_TOKEN=
