# Public browser variables
VITE_INSFORGE_URL=https://your-app.insforge.app
VITE_INSFORGE_ANON_KEY=replace_with_insforge_anon_key

# Server-only secrets. Never expose these in client code.
INSFORGE_API_KEY=replace_with_server_side_insforge_key
PORTALY_API_KEY=pcs_test_replace_with_portaly_vibe_key
PORTALY_CALLBACK_SECRET=replace_with_portaly_callback_secret
PORTALY_API_HOST=https://portaly.cc
PORTALY_MCP_TOKEN=replace_with_portaly_vibe_mcp_token

# Optional formal test login for a deployed reference site.
# Keep the password and session token in Vercel/hosting env vars only.
SKILLS_SCHOOL_TEST_EMAIL=owner@example.com
SKILLS_SCHOOL_TEST_PASSWORD=replace_with_private_test_password
SKILLS_SCHOOL_SESSION_TOKEN=replace_with_random_64_char_token
SKILLS_SCHOOL_TEST_ROLE=admin
SIGNAL_BRIEF_TEST_EMAIL=owner@example.com
SIGNAL_BRIEF_TEST_PASSWORD=replace_with_private_test_password
SIGNAL_BRIEF_SESSION_TOKEN=replace_with_random_64_char_token
SIGNAL_BRIEF_TEST_ROLE=admin

# App URLs
APP_BASE_URL=http://localhost:5176
ALLOWED_ORIGINS=http://localhost:5176,http://127.0.0.1:5176

# Optional analytics and messaging
GA_MEASUREMENT_ID=
LINE_CHANNEL_ACCESS_TOKEN=
