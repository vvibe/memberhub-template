# Optional preview login for local demos and forked templates.
# Keep the password and session token in local env files or hosting env vars only.
MEMBERHUB_PREVIEW_EMAIL=owner@example.com
MEMBERHUB_PREVIEW_PASSWORD=replace_with_private_preview_password
MEMBERHUB_PREVIEW_SESSION_TOKEN=replace_with_random_64_char_token
MEMBERHUB_PREVIEW_ROLE=admin
